# LLM translation backend
# These placeholders are replaced by GitHub Secrets in CI.
# For local testing, fill in your own keys.
TRANSLATION_API_KEY=sk-your-key
TRANSLATION_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8
TRANSLATION_BASE_URL=http://your-llm-host:4000/v1
OCR_MODEL=deepseek-ai/DeepSeek-OCR-2

# RetainPDF for scanned PDFs
RETAIN_ENABLED=1
RETAIN_API_KEY=
RETAIN_OCR_PROVIDER=paddle
RETAIN_PADDLE_TOKEN=

# System prompt
CUSTOM_SYSTEM_PROMPT=/no_think You are a professional, authentic machine translation engine.

# Defaults
DEFAULT_LANG_IN=en
DEFAULT_LANG_OUT=vi
QPS=4

# API auth
API_KEYS=your-api-key
NEXT_PUBLIC_API_KEY=your-api-key
