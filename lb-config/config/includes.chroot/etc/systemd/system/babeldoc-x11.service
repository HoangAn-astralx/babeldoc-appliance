[Unit]
Description=X11 Display Server cho kiosk
After=systemd-user-sessions.service

[Service]
User=babeldoc
PAMName=login
TTYPath=/dev/tty1
ExecStartPre=/bin/bash -c 'chvt 1'
ExecStart=/usr/bin/startx /usr/local/bin/openbox-kiosk.sh -- :0 vt1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
